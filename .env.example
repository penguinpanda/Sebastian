APP_NAME=Sebastian
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TIMEOUT_MS=5000
LLM_RETRY_MAX=2
DATABASE_URL=postgresql+psycopg://sebastian:sebastian@localhost:5432/sebastian
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE_SECONDS=1800
DB_CONNECT_TIMEOUT_SECONDS=3
REDIS_URL=redis://localhost:6379/0
AGENT_RATE_LIMIT_MAX_REQUESTS=20
AGENT_RATE_LIMIT_WINDOW_SECONDS=60
AGENT_TASK_STATUS_TTL_SECONDS=86400
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_MEMORY_INDEX=memory_index
MEMORY_SEARCH_TOP_K_DEFAULT=5
MEMORY_EMBEDDING_DIMS=64
MEMORY_HYBRID_RRF_K=60
MCP_IDEMPOTENCY_TTL_SECONDS=3600
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
